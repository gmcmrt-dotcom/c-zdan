# Wallet — production environment for the Node API + Vite web bundle.
# Copy to deploy/.env on the deploy host. NEVER commit a real .env to git.
# Generate every secret with: openssl rand -hex 32

# ─── API (apps/api) ───────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# P0-14 — use the dedicated wallet_app role (see deploy/postgres-roles.sql.example)
# and require SSL on the wire. The migration job should connect with wallet_migrate.
DATABASE_URL=postgres://wallet_app:CHANGE_ME@localhost:5433/wallet?sslmode=require

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# 32 random bytes (64 hex chars). Encrypts user_mfa_factors.secret_encrypted.
MFA_ENCRYPTION_KEY=

# Local FS storage (HMAC-signed URLs)
STORAGE_ROOT=./storage
STORAGE_SIGNING_SECRET=

# Comma-separated allow-list of HTTP origins (no "*" in production).
CORS_ORIGINS=https://wallet.example.com

# Merchant HMAC
MERCHANT_HMAC_PEPPER=
MERCHANT_CASHOUT_CALLBACK_SECRET=

# Production safety: the API refuses to start with MOCK_FNS_ENABLED=true here.
MOCK_FNS_ENABLED=false
AFFILIATE_SYSTEM_ENABLED=false

# Optional integrations — leave blank to disable.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
TG_BOT_TOKEN=
# VIRUSTOTAL_API_KEY removed in the K batch (audit Q15). Use a ClamAV
# sidecar on file write for production scanning — see DEPLOY_WORKFLOW.md.
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=

# Aninda (kripto / banka / papara) — fill the ones you actually use.
ANINDA_API_BASE=
ANINDA_KEY=
ANINDA_PAYMENT_METHOD_ID=
ANINDA_BANKA_PAYMENT_METHOD_ID=
ANINDA_PAPARA_PAYMENT_METHOD_ID=
ANINDA_DEFAULT_BANK_ID=

# ─── Web bundle (apps/web/.env.local at build time) ───────────────────────────

VITE_API_BASE_URL=/api
VITE_SOCKET_URL=/ws
VITE_API_PROXY_TARGET=http://localhost:3000
VITE_SCOPE_STRICT=false
VITE_ADMIN_HOST=admin.
VITE_MERCHANT_HOST=merchant.
VITE_AFFILIATE_ENABLED=false
VITE_MFA_ENFORCEMENT=false
